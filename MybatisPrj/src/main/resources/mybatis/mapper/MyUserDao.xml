<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.MybatisPrj.jdbc.IMyUserDao">
	<select id="list" resultType="com.example.MybatisPrj.jdbc.MyUserDto">
		select id, pw from myuser
	</select>
	
	<select id="getUser" resultType="com.example.MybatisPrj.jdbc.MyUserDto">
		select * from myuser where id = #{id}
	</select>
	
	<insert id="insertUser" parameterType="com.example.MybatisPrj.jdbc.MyUserDto">
		insert into myuser values (#{param1}, #{param2})
	</insert>
	
	<delete id="deleteUser" parameterType="com.example.MybatisPrj.jdbc.MyUserDto">
		delete myuser where id = #{param1}
	</delete>
	
	<update id="updateUser" parameterType="com.example.MybatisPrj.jdbc.MyUserDto">
		update myuser set pw = #{param1} where id = #{param2}
	</update>
</mapper>